# Copy to ".env" and fill in (never commit .env):
#   cp .env.example .env
#
# Docker Compose loads this file automatically (same directory as docker-compose.webapp.yml).
# The webapp also loads .env when you run uvicorn locally.

# Required for signing login cookies (generate: openssl rand -hex 32)
SECRET_KEY=

# Admins from ADMIN_EMAIL_1..3 / ADMIN_BOOTSTRAP: first boot creates all when DB is empty; on later
# restarts, any extra env accounts that are not in the DB yet are auto-created (see ensure_missing_env_admins).
ADMIN_EMAIL_1=
ADMIN_PASSWORD_1=
# If login always fails but email/password are correct in .env: the SQLite user may have been
# created with a bad hash. Set the two lines below, restart the API once, log in, then remove them
# and restart again (do not leave sync enabled in production).
# SYNC_ADMIN_PASSWORD_FROM_ENV=1
# If login fails in Docker but worked locally: passwords with `$` were broken by older compose files
# that used `${ADMIN_PASSWORD_1}` (Compose expands `$` on the host). Use the current compose file;
# if the DB was first created with a mangled password, use SYNC_ADMIN_PASSWORD_FROM_ENV or wipe the volume.

# Optional: second and third admin (also picked up after first user exists — restart API once)
# ADMIN_EMAIL_2=
# ADMIN_PASSWORD_2=
# ADMIN_EMAIL_3=
# ADMIN_PASSWORD_3=

# Or a JSON array of {email, password} instead of ADMIN_EMAIL_* (merged with missing-user creation)
# ADMIN_BOOTSTRAP=[{"email":"a@b.com","password":"..."}]

# Pipeline / API (same keys as your desktop app)
# OPENROUTER_API_KEY=
# (add any other keys your processors read from the environment)

# Local dev: if you run only uvicorn (no Celery worker), jobs stay stuck in Redis unless you either
# start `celery -A webapp.celery_app worker --loglevel=info` (same REDIS_URL/JOBS_ROOT/DATABASE_URL),
# or bypass the broker:
# WEBAPP_RUN_TASKS_INLINE=1

# Optional overrides (defaults are set in docker-compose for containers)
# REDIS_URL=redis://redis:6379/0
# DATABASE_URL=sqlite:////data/webapp.db
# JOBS_ROOT=/data/jobs
#
# Where SQLite + job files actually live:
# - Local uvicorn (no override): PROJECT_ROOT/data/webapp.db and PROJECT_ROOT/data/jobs/ (see webapp/config.py).
# - Docker (docker-compose.webapp.yml): ./data on the HOST is bind-mounted to /data in api + worker
#   (same paths as local: webapp.db + jobs/). Rebuild/restart containers keeps ./data; only deleting ./data
#   removes data. If you used an older compose with named volume app-data, copy that volume into ./data once
#   (e.g. docker compose run --rm -v OLD_VOLUME:/from -v "$(pwd)/data":/to alpine cp -a /from/. /to/)
#   then start with this compose file.
# Only webapp.db is used unless DATABASE_URL points elsewhere.
# DBeaver / tools: with Docker bind mount, open the HOST file next to compose: ./data/webapp.db
# (same as /data/webapp.db inside the container). Refresh or reconnect after creating jobs.

# Docker build: if you see "failed to fetch anonymous token" / connection reset to auth.docker.io,
# retry when the network is stable, or pull the base image once (docker pull python:3.11-slim-bookworm),
# or point builds at a mirror / private copy of the same image:
# PYTHON_BASE_IMAGE=your-registry.example.com/python:3.11-slim-bookworm
